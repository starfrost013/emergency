{
    "configurations": [
    {
        "name": "(gdb) Launch - Windows 1.01 Debug Kernel",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceFolder}/build/src/emergency",
        "args": ["/media/starfrost/SSD/Users/mario/ModernPersonality/research/win1.01/debug/KERNEL.EXE"],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}/build/src",
        "environment": [
            { "name": "EMERGENCY_DEBUG", "value": "cpu,int,port,dos,video,verbose"}
        ],
        "externalConsole": false,
        "MIMode": "gdb",
        "setupCommands": [
            {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            },
            {
                "description": "Set Disassembly Flavor to Intel",
                "text": "-gdb-set disassembly-flavor intel",
                "ignoreFailures": true
            }
        ]
    }
    ]
}